{
    "name": "kkxdev/laravel-apple-iap",
    "description": "Apple In-App Purchase package for Laravel — receipt validation, App Store Server API, JWS verification, and server notifications.",
    "keywords": ["laravel", "apple", "in-app-purchase", "iap", "storekit", "app-store"],
    "homepage": "https://github.com/kkxdev/laravel-apple-iap",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "kkxdev"
        }
    ],
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/cache": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/console": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/events": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/routing": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "firebase/php-jwt": "^6.0",
        "psr/log": "^1.0|^2.0|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Kkxdev\\AppleIap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kkxdev\\AppleIap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kkxdev\\AppleIap\\AppleIapServiceProvider"
            ],
            "aliases": {
                "AppleIap": "Kkxdev\\AppleIap\\Facades\\AppleIap"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
